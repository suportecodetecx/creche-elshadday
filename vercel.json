{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)/",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "trailingSlash": false,
  "functions": {
    "app.py": {
      "maxDuration": 60,
      "memory": 1024,
      "maxRequestBodySize": "15mb"
    }
  }
}